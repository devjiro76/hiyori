{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-schema/main/tauri.conf.json.schema",
  "productName": "Hiyori",
  "version": "0.1.0",
  "identifier": "io.molroo.hiyori",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Hiyori",
        "width": 580,
        "height": 852,
        "center": true,
        "visible": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": false,
        "minWidth": 290,
        "minHeight": 426,
        "maxWidth": 1160,
        "maxHeight": 1704
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
